# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# electron compiled output & packaged releases
/dist/electron/
/dist/release/

# typescript incremental build cache
tsconfig.tsbuildinfo

# misc
.DS_Store
*.pem

# IDE
.vscode/
.idea/

# env
.env
.env.local
.env.*.local

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# uploads (user-uploaded media for flow nodes)
public/uploads/

# user runtime data — never commit
data/wautochat.db
data/wautochat.db-shm
data/wautochat.db-wal
data/avatars/
data/media/

# WhatsApp auth tokens — SECRET, anyone with these can hijack your sessions
tokens/
